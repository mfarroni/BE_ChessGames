# Versione: 1.0.2
# Data/Ora: 07/07/2026 15:30:00 (Ora di Roma)
# Descrizione: Aggiunte le variabili ADMIN_USERNAME/ADMIN_PASSWORD per le credenziali del pannello amministratore.

# Connection URL for PostgreSQL Database (e.g. hosted on Render or Supabase)
DATABASE_URL=

# Port on which the express server runs (defaults to 3000 if not specified)
PORT=3000

# Credenziali del pannello amministratore.
# Consigliato impostarle in produzione (es. su Render) per avere credenziali
# stabili e mai committate nel repository. Se ADMIN_PASSWORD non è impostata,
# al primo avvio il server genera una password temporanea casuale e la stampa
# UNA VOLTA nello stdout del server (mai in una risposta HTTP).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Chiave API transazionale di Brevo (Transactional Emails API Key).
# ATTENZIONE: deve essere la chiave API transazionale, NON quella con scope MCP.
# Generabile dalla dashboard Brevo in SMTP & API > API Keys.
BREVO_API_KEY=

# Indirizzo email del mittente delle comunicazioni (deve essere un mittente verificato su Brevo)
BREVO_SENDER_EMAIL=no-reply@granmasterchess.it

# Nome del mittente mostrato nelle email inviate
BREVO_SENDER_NAME="Circolo degli Scacchi"
